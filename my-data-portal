<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NBHS Table Tennis Club</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* This hides sections by default */
        .page-section { display: none; }
        /* This shows the active section */
        .active { display: block; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen">

    <nav class="bg-blue-800 text-white p-4 shadow-md">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <button onclick="showPage('home')" class="text-xl font-bold">NBHS TT Hub</button>
            <div class="space-x-4 text-sm md:text-base">
                <button onclick="showPage('ladder')" class="hover:text-blue-200 uppercase font-semibold">Ranking</button>
                <button onclick="showPage('brackets')" class="hover:text-blue-200 uppercase font-semibold">Brackets</button>
            </div>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-6">

        <section id="home" class="page-section active space-y-8">
            <div class="text-center py-10">
                <h1 class="text-4xl font-extrabold text-blue-900">Welcome, Players.</h1>
                <p class="text-slate-600 mt-2">Track your Elo, view brackets, and dominate the table.</p>
            </div>

            <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                <h2 class="text-lg font-bold mb-4">🔍 Quick Player Search</h2>
                <div class="flex gap-2">
                    <input type="text" id="searchInput" placeholder="Enter name (e.g. Fanda)..." 
                        class="flex-1 p-3 border rounded-xl outline-none focus:ring-2 focus:ring-blue-500">
                    <button onclick="searchPlayer()" class="bg-blue-600 text-white px-6 py-3 rounded-xl font-bold">Search</button>
                </div>
                <div id="searchResult" class="hidden mt-6 p-4 bg-blue-50 border border-blue-100 rounded-xl">
                    </div>
            </div>
        </section>

        <section id="ladder" class="page-section space-y-6">
            <h2 class="text-3xl font-bold text-blue-900">Overall Ranking Ladder</h2>
            <div class="bg-white rounded-2xl shadow-sm border overflow-hidden">
                <table class="w-full text-left">
                    <thead class="bg-slate-100">
                        <tr>
                            <th class="p-4">Rank</th>
                            <th class="p-4">Name</th>
                            <th class="p-4 text-right">Elo Rating</th>
                        </tr>
                    </thead>
                    <tbody id="ladder-table"></tbody>
                </table>
            </div>
        </section>

        <section id="brackets" class="page-section space-y-6">
            <h2 class="text-3xl font-bold text-blue-900">Weekly Brackets</h2>
            <div class="grid gap-4">
                <div class="bg-white p-5 rounded-xl border-l-8 border-blue-600 shadow-sm">
                    <span class="text-xs font-bold text-blue-600 uppercase">Court 1</span>
                    <p class="text-lg font-semibold mt-1">Player A vs Player D</p>
                </div>
                <div class="bg-white p-5 rounded-xl border-l-8 border-blue-600 shadow-sm">
                    <span class="text-xs font-bold text-blue-600 uppercase">Court 2</span>
                    <p class="text-lg font-semibold mt-1">Player B vs Player C</p>
                </div>
            </div>
        </section>

    </main>

    <script>
        // THE DATA
        const players = [
            { name: "Fanda Gong", elo: 1450, stats: "W: 12 | L: 2" },
            { name: "Alex Smith", elo: 1320, stats: "W: 8 | L: 5" },
            { name: "Julian Wong", elo: 1280, stats: "W: 7 | L: 6" }
        ];

        // PAGE SWITCHER LOGIC
        function showPage(pageId) {
            // Hide all sections
            document.querySelectorAll('.page-section').forEach(section => {
                section.classList.remove('active');
            });
            // Show the clicked one
            document.getElementById(pageId).classList.add('active');
        }

        // SEARCH LOGIC
        function searchPlayer() {
            const input = document.getElementById('searchInput').value.toLowerCase();
            const resultDiv = document.getElementById('searchResult');
            const found = players.find(p => p.name.toLowerCase().includes(input));

            if (found && input !== "") {
                resultDiv.innerHTML = `
                    <h3 class="text-xl font-bold text-blue-800">${found.name}</h3>
                    <p class="text-slate-700"><strong>Rating:</strong> ${found.elo}</p>
                    <p class="text-slate-700"><strong>History:</strong> ${found.stats}</p>
                `;
                resultDiv.classList.remove('hidden');
            } else {
                alert("Player not found!");
            }
        }

        // AUTO-LOAD LADDER
        const table = document.getElementById('ladder-table');
        players.sort((a,b) => b.elo - a.elo).forEach((p, i) => {
            table.innerHTML += `
                <tr class="border-t">
                    <td class="p-4 font-bold text-slate-400">#${i+1}</td>
                    <td class="p-4 font-semibold">${p.name}</td>
                    <td class="p-4 text-right font-mono text-blue-600 font-bold">${p.elo}</td>
                </tr>
            `;
        });
    </script>
</body>
</html>
